# Puerto en el que correrá el servidor Express
PORT=PORT

# URL de conexión directa de Supabase (PostgreSQL)
# Encuentra esto en Supabase -> Project Settings -> Database -> Connection string (URI)
DATABASE_URL=DATABASE_URL

# Secreto JWT para firmar y validar tokens de sesión
JWT_SECRET=JWT_SECRET

# Tiempo de expiración de las credenciales de sesión
JWT_EXPIRES_IN=NUMBER

# Entorno de ejecución (development, production)
NODE_ENV=NODE_ENV

# URL del Frontend (para configurar CORS correctamente)
FRONTEND_URL=http://localhost:3000
